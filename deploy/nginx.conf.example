# nginx pass-through for paper-market under /paper-market (host port 26223 from docker-compose).
# The app serves the /paper-market prefix itself (BASE_PATH), so DO NOT strip it:
# proxy_pass has no trailing slash/path.
location /paper-market {
    proxy_pass http://127.0.0.1:26223;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # Server-Sent Events (/api/stream): stream immediately, don't buffer or time out.
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_buffering off;
    proxy_read_timeout 3600s;
}
